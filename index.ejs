<!doctype html>
<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Anketa o cvičení</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
  </head>

  <body class="bg-light">

    <header class="text-center py-4">
      <h1>Anketa o cvičení</h1>
    </header>

    <main class="container">
      <div class="card shadow p-4">

        <form id="anketaForm" action="/submit" method="POST">

          <div class="mb-3">
            <label class="form-label">1. Jsi muž nebo žena?</label>
            <div>
              <input id="muz" type="radio" name="pohlavi" value="muz">
              <label for="muz">Muž</label>

              <input id="zena" class="ms-3" type="radio" name="pohlavi" value="zena">
              <label for="zena">Žena</label>
            </div>
          </div>

         
          <div class="mb-3">
            <label class="form-label" for="cviceni">2. Kolikrát týdně cvičíš?</label>
            <select class="form-select" name="cviceni">
              <option value="0">0x</option>
              <option value="1-2">1-2x</option>
              <option value="3-4">3-4x</option>
              <option value="5+">5x a více</option>
            </select>
          </div>

        
          <div class="mb-3">
            <label class="form-label" for="typ">3. Co děláš častěji?</label>
            <select class="form-select" name="typ">
              <option value="posilovna">Posilovna</option>
              <option value="sport">Sport</option>
              <option value="oboji">Obojí</option>
            </select>
          </div>

       
          <div class="mb-3">
            <label class="form-label" for="delka">4. Jak dlouho cvičíš?</label>
            <select class="form-select" name="delka">
              <option value="30">Méně než 30 minut</option>
              <option value="60">30-60 minut</option>
              <option value="60plus">Více než 1 hodina</option>
            </select>
          </div>

         
          <div class="mb-3">
            <label class="form-label" for="duvod">5. Proč cvičíš?</label>
            <select class="form-select" name="duvod">
              <option value="zdravi">Zdraví</option>
              <option value="vzhled">Vzhled</option>
              <option value="zabava">Zábava</option>
            </select>
          </div>

          <button class="btn btn-primary w-100" type="submit">
            Odeslat
          </button>

        </form>

      </div>
    </main>

  </body>
</html>